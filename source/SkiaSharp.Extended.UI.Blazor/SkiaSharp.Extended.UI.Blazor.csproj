<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- <Nullable>enable</Nullable> -->
    <AssemblyName>SkiaSharp.Extended.UI.Blazor</AssemblyName>
    <RootNamespace>SkiaSharp.Extended.UI.Blazor</RootNamespace>
    <AddRazorSupportForMvc>false</AddRazorSupportForMvc>
    <StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>SkiaSharp.Extended.UI.Blazor</PackageId>
    <Title>Additional SkiaSharp controls for Blazor</Title>
    <Description>This package adds a touch-enabled SkiaSharp canvas view for Blazor, providing unified touch/pointer event support across mouse, touch, and stylus inputs.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Let Microsoft.TypeScript.MSBuild compile .ts → .js via tsconfig.json -->
    <TypeScriptCompileBlocked>false</TypeScriptCompileBlocked>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.TypeScript.MSBuild" Version="5.7.3" PrivateAssets="all" />
    <PackageReference Include="SkiaSharp" Version="3.119.1" />
    <PackageReference Include="SkiaSharp.Views.Blazor" Version="3.119.1" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.AspNetCore.Components" />
    <Using Include="Microsoft.AspNetCore.Components.Web" />
    <Using Include="Microsoft.JSInterop" />
    <Using Include="SkiaSharp" />
    <Using Include="SkiaSharp.Views.Blazor" />
  </ItemGroup>

  <!-- TypeScript source lives in Scripts/ and is compiled to wwwroot/ by Microsoft.TypeScript.MSBuild -->
  <ItemGroup>
    <Content Remove="Scripts\**" />
    <TypeScriptCompile Include="Scripts\**\*.ts" />
  </ItemGroup>

</Project>
