<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <AssemblyName>SkiaSharp.Extended.UI.Blazor</AssemblyName>
    <RootNamespace>SkiaSharp.Extended.UI.Blazor</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>SkiaSharp.Extended.UI.Blazor</PackageId>
    <Title>Additional SkiaSharp controls for Blazor</Title>
    <Description>This package adds additional SkiaSharp controls and utilities for Blazor applications.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.0" />
    <PackageReference Include="SkiaSharp.Views.Blazor" Version="3.119.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SkiaSharp.Extended\SkiaSharp.Extended.csproj" />
  </ItemGroup>

</Project>
