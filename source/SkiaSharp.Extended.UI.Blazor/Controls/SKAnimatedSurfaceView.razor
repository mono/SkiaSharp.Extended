@namespace SkiaSharp.Extended.UI.Blazor.Controls

@if (UseGL)
{
    <SkiaSharp.Views.Blazor.SKGLView @ref="_glView"
                                      OnPaintSurface="HandleGLPaintSurface"
                                      @attributes="AdditionalAttributes" />
}
else
{
    <SkiaSharp.Views.Blazor.SKCanvasView @ref="_canvasView"
                                          OnPaintSurface="HandleCanvasPaintSurface"
                                          @attributes="AdditionalAttributes" />
}
