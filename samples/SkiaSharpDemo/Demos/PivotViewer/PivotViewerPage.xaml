<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pv="clr-namespace:SkiaSharp.Extended.UI.Maui.PivotViewer;assembly=SkiaSharp.Extended.UI.Maui.PivotViewer"
             x:Class="SkiaSharpDemo.Demos.PivotViewerPage"
             Title="PivotViewer">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header: collection picker + URL bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="8" ColumnSpacing="8">
            <Picker Grid.Column="0" x:Name="collectionPicker"
                    Title="Collection"
                    SelectedIndexChanged="OnCollectionPickerChanged"
                    FontSize="12" />
            <Entry Grid.Column="1" x:Name="urlEntry"
                   Placeholder="Or enter a CXML URL"
                   FontSize="12" />
            <Button Grid.Column="2" Text="Load URL"
                    Clicked="OnLoadUrlClicked"
                    FontSize="12" Padding="8,4" />
        </Grid>

        <!-- PivotViewer -->
        <pv:SKPivotViewerView Grid.Row="1"
                               x:Name="pivotViewerView"
                               BackgroundColor="#F0F0F0" />

        <!-- Status bar -->
        <Label Grid.Row="2" x:Name="statusLabel"
               Text="Select a collection above"
               FontSize="12" TextColor="Gray"
               Padding="8"
               VerticalTextAlignment="Center" />

    </Grid>

</ContentPage>
