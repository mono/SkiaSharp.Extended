<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="SkiaSharpDemo.Demos.GesturePage"
             Title="Gesture Demo">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Settings Panel -->
        <VerticalStackLayout Grid.Row="0" Padding="10" Spacing="5" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <Label Text="Selection Mode:" FontSize="12" />
            <HorizontalStackLayout Spacing="10">
                <RadioButton Content="Immediate" x:Name="modeImmediate" IsChecked="True" CheckedChanged="OnModeChanged" />
                <RadioButton Content="Tap to Select" x:Name="modeTapToSelect" CheckedChanged="OnModeChanged" />
                <RadioButton Content="Long Press" x:Name="modeLongPress" CheckedChanged="OnModeChanged" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        
        <!-- Gesture Surface -->
        <controls:SKGestureSurfaceView x:Name="gestureView"
                                        Grid.Row="1"
                                        TapDetected="OnTap"
                                        DoubleTapDetected="OnDoubleTap"
                                        LongPressDetected="OnLongPress"
                                        PanDetected="OnPan"
                                        PinchDetected="OnPinch"
                                        RotateDetected="OnRotate"
                                        FlingDetected="OnFling"
                                        DragStarted="OnDragStarted"
                                        DragUpdated="OnDragUpdated"
                                        DragEnded="OnDragEnded" />

        <!-- Status Panel -->
        <ScrollView Grid.Row="2" HeightRequest="120" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <VerticalStackLayout Padding="10" Spacing="2">
                <Label x:Name="statusLabel" Text="Touch the canvas to begin" FontSize="14" FontAttributes="Bold" />
                <Label x:Name="eventLog1" Text="" FontSize="11" TextColor="Gray" />
                <Label x:Name="eventLog2" Text="" FontSize="11" TextColor="Gray" />
                <Label x:Name="eventLog3" Text="" FontSize="11" TextColor="Gray" />
                <Label x:Name="eventLog4" Text="" FontSize="11" TextColor="Gray" />
                <Label x:Name="eventLog5" Text="" FontSize="11" TextColor="Gray" />
            </VerticalStackLayout>
        </ScrollView>
        
    </Grid>

</ContentPage>
