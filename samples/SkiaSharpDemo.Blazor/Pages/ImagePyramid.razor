@page "/image-pyramid"
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@using SkiaSharp.Extended
@using SkiaSharpDemo.Blazor.Components.ImagePyramid

<PageTitle>Image Pyramid</PageTitle>

<div class="ip-toolbar">
    <label>Zoom: <strong class="ip-zoom-label">@_zoom.ToString("F2")×</strong></label>
    <input type="range" min="0" max="1" step="0.001" value="@_sliderValue"
           @oninput="OnZoomSlider" style="width:200px;vertical-align:middle;" />
    <button @onclick="OnResetView" style="margin-left:8px;">Fit</button>
    <div class="ip-url-row">
        <input type="url" @bind="_urlInput" @bind:event="oninput" placeholder="Enter DZI, DZC, or IIIF URL…"
               @onkeydown="OnUrlKeyDown" class="ip-url-input" />
        <button @onclick="OnLoadUrl" disabled="@_urlLoading">@(_urlLoading ? "Loading…" : "Load")</button>
        <select @onchange="OnExampleSelected" class="ip-example-select" title="Load an example image">
            <option value="">— Examples —</option>
            <optgroup label="Deep Zoom (DZI)">
                <option value="https://openseadragon.github.io/example-images/highsmith/highsmith.dzi">Highsmith photos (7026×9221)</option>
                <option value="https://openseadragon.github.io/example-images/duomo/duomo.dzi">Duomo di Firenze (13920×10200)</option>
                <option value="https://raw.githubusercontent.com/mono/SkiaSharp.Extended/refs/heads/feature/deep-zoom-static-preview/resources/collections/testgrid/testgrid.dzi">Test Grid (32768×32768 — zoom in to see tiles)</option>
                <option value="https://raw.githubusercontent.com/mono/SkiaSharp.Extended/refs/heads/feature/deep-zoom-static-preview/resources/collections/conceptcars/deepzoom/10489820633895493292390866.dzi">Concept Car (1024×682)</option>
            </optgroup>
            <optgroup label="IIIF v2">
                <option value="https://iiif.wellcomecollection.org/image/b20432033_B0008608.JP2">Wellcome Collection (3543×2480)</option>
                <option value="https://media.nga.gov/iiif/public/objects/4/6/2/5/8/46258-primary-0-nativeres.ptif">National Gallery of Art (7993×8195)</option>
                <option value="https://tile.loc.gov/image-services/iiif/service:pnp:highsm:14000:14095">Library of Congress (4717×5951)</option>
                <option value="https://stacks.stanford.edu/image/iiif/hg676jb4964%2F0380_796-44">Stanford University (5426×3820)</option>
                <option value="https://iiif.ub.uni-leipzig.de/iiif/j2k/0000/0107/0000010732/00000072.jpx">Leipzig University Library (5284×2410)</option>
                <option value="https://iiif.bodleian.ox.ac.uk/iiif/image/9cca8fdd-4a61-4429-8ac1-f648764b4d6d">Bodleian Libraries, Oxford (5776×9125)</option>
                <option value="https://www.e-codices.unifr.ch/loris/bge/bge-cl0015/bge-cl0015_e001.jp2">e-codices Swiss manuscript (3328×4992)</option>
            </optgroup>
            <optgroup label="IIIF v3">
                <option value="https://iiif.io/api/image/3.0/example/reference/918ecd18c2592080851777620de9bcb5-fountain">IIIF.io fountain (3024×4032)</option>
            </optgroup>
        </select>
    </div>
</div>

<div class="ip-layout @(_showInspector ? "ip-with-inspector" : "")">

    <div class="ip-canvas-area"
         @onmousedown="OnMouseDown"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp"
         @ontouchstart="OnTouchStart"
         @ontouchmove="OnTouchMove"
         @ontouchend="OnTouchEnd"
         @ontouchstart:preventDefault
         @ontouchmove:preventDefault>
        @if (_statusText != null)
        {
            <div class="ip-status">@_statusText</div>
        }
        @if (_errorMessage != null)
        {
            <div class="ip-error">@_errorMessage</div>
        }
        <SKGLView @ref="_canvas"
                  OnPaintSurface="OnPaintSurface"
                  style="display:block; width:100%; height:100%;" />
    </div>

    @if (_showInspector)
    {
        <ImagePyramidInspector
            Controller="_controller"
            @bind-ShowTileBorders="_showTileBorders"
            @bind-ShowTileBorders:after="OnDebugOptionsChanged"
            @bind-EnableLodBlending="_enableLodBlending"
            @bind-EnableLodBlending:after="OnDebugOptionsChanged"
            @bind-UseBrowserCache="_useBrowserCache"
            @bind-UseBrowserCache:after="OnCacheTypeChanged"
            @bind-CacheDelayEnabled="_cacheDelayEnabled"
            @bind-CacheDelayEnabled:after="OnCacheDelayChanged"
            @bind-CacheDelayMin="_cacheDelayMin"
            @bind-CacheDelayMin:after="OnCacheDelayChanged"
            @bind-CacheDelayMax="_cacheDelayMax"
            @bind-CacheDelayMax:after="OnCacheDelayChanged"
            @bind-CacheCapacity="_cacheCapacity"
            @bind-CacheCapacity:after="OnCacheSizeChanged"
            @bind-DebugZoom="_debugZoom"
            @bind-DebugZoom:after="OnDebugZoomChanged"
            OnDebugOptionsChanged="OnDebugOptionsChanged"
            OnCacheTypeChanged="OnCacheTypeChanged"
            OnCacheDelayChanged="OnCacheDelayChanged"
            OnCacheSizeChanged="OnCacheSizeChanged"
            OnClearCache="OnClearCache" />
    }
</div>

<button class="ip-toggle-btn" @onclick="ToggleInspector">
    @(_showInspector ? "Hide Inspector" : "Show Inspector")
</button>

@code {
    private const string DefaultDziUrl =
        "https://openseadragon.github.io/example-images/highsmith/highsmith.dzi";

    private SKGLView? _canvas;
    private SKImagePyramidController? _controller;
    private string? _statusText;
    private string? _errorMessage;
    private bool _showInspector = true;

    // Debug overlay toggles
    private bool _showTileBorders;
    private bool _enableLodBlending = true;
    private DebugBorderRenderer? _debugRenderer;
    private bool _cacheDelayEnabled;
    private int  _cacheDelayMin;
    private int  _cacheDelayMax = 500;
    private bool _useBrowserCache;
    private int  _cacheCapacity = 1024;
    private DelayTileProvider? _delayProvider;
    // Debug zoom: scales the entire canvas to reveal what is off-screen (0.1–1.0)
    private float _debugZoom = 1.0f;

    // URL input
    private string _urlInput = DefaultDziUrl;
    private bool _urlLoading = false;

    // Pan state
    private bool _isDragging;
    private double _lastMouseX;
    private double _lastMouseY;

    // Zoom slider value (1.0 = image fills control width)
    private double _zoom = 1.0;
    // Logarithmic slider position (0-1)
    private double _sliderValue = 0.0;

    // Log zoom range for the slider
    private const double MinZoom = 0.01;
    private const double MaxZoom = 100.0;
    private static double ZoomToSlider(double zoom)
        => (Math.Log(zoom) - Math.Log(MinZoom)) / (Math.Log(MaxZoom) - Math.Log(MinZoom));
    private static double SliderToZoom(double slider)
        => MinZoom * Math.Pow(MaxZoom / MinZoom, slider);

    private System.Threading.Timer? _inspectorTimer;
    private DotNetObjectReference<ImagePyramid>? _thisRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Wire up window-resize → canvas invalidate via JS
        _thisRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("deepZoomRegisterResize", _thisRef);

        _delayProvider = new DelayTileProvider(BuildInnerProvider());
        _debugRenderer = new DebugBorderRenderer(new SkiaSharp.Extended.SKImagePyramidRenderer());
        _controller = new SKImagePyramidController();
        _controller.EnableLodBlending = _enableLodBlending;
        _controller.InvalidateRequired += OnInvalidateRequired;

        // Refresh inspector every 500ms while tiles are loading
        _inspectorTimer = new System.Threading.Timer(_ =>
        {
            if (_controller == null) return;
            // Only refresh UI if something the inspector shows has changed
            var prevZoom = _zoom;
            SyncZoomFromViewport();
            var changed = Math.Abs(_zoom - prevZoom) > 0.001 || !_controller.IsIdle;
            if (changed)
                InvokeAsync(StateHasChanged);
        }, null, 500, 500);

        await LoadFromUrlAsync(DefaultDziUrl);
    }

    private int _lastControlWidth;
    private int _lastControlHeight;

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        if (_controller == null || _debugRenderer == null) return;
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.White);

        var w = e.BackendRenderTarget.Width;
        var h = e.BackendRenderTarget.Height;

        // Guard: only call SetControlSize when dimensions actually change to prevent
        // triggering re-renders from tile InvalidateRequired → StateHasChanged → layout shift → repeat.
        if (w != _lastControlWidth || h != _lastControlHeight)
        {
            _lastControlWidth  = w;
            _lastControlHeight = h;
            _controller.SetControlSize(w, h);
        }

        // Debug zoom: scale the entire canvas so we can see what's off-screen.
        // Translate first to center the scaled-down content, then scale.
        // This ensures all four edges are equally visible rather than pinning top-left.
        bool hasDebugZoom = _debugZoom < 0.999f;
        if (hasDebugZoom)
        {
            canvas.Save();
            // Translate by half the "lost" margin so content is centered
            canvas.Translate(w * (1f - _debugZoom) / 2f, h * (1f - _debugZoom) / 2f);
            canvas.Scale(_debugZoom);
        }

        _controller.Update();
        _debugRenderer.Canvas = canvas;
        _controller.Render(_debugRenderer);

        // Draw canvas bounds rect to show where the screen edge is.
        // We're still in the scaled+translated coordinate space, so (0,0,w,h) maps
        // to the true canvas origin and size — the red border shows the real screen edges.
        if (hasDebugZoom)
        {
            using var dashEffect = SKPathEffect.CreateDash(
                new float[] { 12f / _debugZoom, 6f / _debugZoom }, 0);
            using var borderPaint = new SKPaint
            {
                Color = SKColors.Red,
                Style = SKPaintStyle.Stroke,
                StrokeWidth = 3f / _debugZoom, // keep visually ~3px regardless of zoom
                PathEffect = dashEffect,
                IsAntialias = true,
            };
            canvas.DrawRect(0, 0, w, h, borderPaint);

            canvas.Restore();
        }
    }

    private void OnInvalidateRequired(object? sender, EventArgs e)
        => InvokeAsync(() => _canvas?.Invalidate());

    [JSInvokable]
    public void OnWindowResize() => InvokeAsync(() => _canvas?.Invalidate());

    // --- Zoom slider ---
    private void OnZoomSlider(ChangeEventArgs e)
    {
        if (_controller == null) return;
        if (!double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var sliderPos)) return;
        _sliderValue = sliderPos;
        _zoom = SliderToZoom(sliderPos);
        _controller.SetZoom(_zoom);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnResetView()
    {
        if (_controller == null) return;
        _controller.ResetView();
        SyncZoomFromViewport();
        InvokeAsync(() => _canvas?.Invalidate());
    }

    // --- URL loading ---
    private async Task OnUrlKeyDown(KeyboardEventArgs e)
    {
        if (_urlLoading) return;
        if (e.Key == "Enter") await OnLoadUrl();
    }

    private async Task OnExampleSelected(ChangeEventArgs e)
    {
        if (_urlLoading) return;
        var url = e.Value?.ToString();
        if (string.IsNullOrEmpty(url)) return;
        _urlInput = url;
        await LoadFromUrlAsync(url);
    }

    private async Task OnLoadUrl()
    {
        var url = _urlInput?.Trim();
        if (string.IsNullOrEmpty(url)) return;
        await LoadFromUrlAsync(url);
    }

    /// <summary>
    /// Fetches a DZI, DZC, or IIIF URL, parses it, and loads it into the controller.
    /// For IIIF URLs, /info.json is appended automatically if not present.
    /// </summary>
    private async Task LoadFromUrlAsync(string url)
    {
        if (_controller == null) return;
        _urlLoading = true;
        _errorMessage = null;
        _statusText = "Loading…";
        StateHasChanged();

        try
        {
            bool isDzc  = url.EndsWith(".dzc", StringComparison.OrdinalIgnoreCase);
            bool isDzi  = url.EndsWith(".dzi", StringComparison.OrdinalIgnoreCase);
            bool isIiif = url.EndsWith("/info.json", StringComparison.OrdinalIgnoreCase)
                || url.Contains("/iiif/", StringComparison.OrdinalIgnoreCase)
                || url.Contains("iiif.io", StringComparison.OrdinalIgnoreCase);

            // Auto-append /info.json for bare IIIF base URLs
            string fetchUrl = url;
            if (isIiif && !url.EndsWith("/info.json", StringComparison.OrdinalIgnoreCase))
                fetchUrl = url.TrimEnd('/') + "/info.json";

            var content = await Http.GetStringAsync(fetchUrl);
            string baseDir = fetchUrl[..fetchUrl.LastIndexOf('/')] + "/";
            string stem    = System.IO.Path.GetFileNameWithoutExtension(fetchUrl);

            if (isDzc)
            {
                var coll = SKImagePyramidDziCollectionSource.Parse(content);
                coll.TilesBaseUri = baseDir;
                _controller.Load(coll, _delayProvider!);
                SyncZoomFromViewport();
                _statusText = $"⚠️ Collection loaded ({coll.ItemCount} images) — DZC collection rendering not yet supported. Use a .dzi URL instead.";
            }
            else if (isIiif || (!isDzi && content.TrimStart().StartsWith("{")))
            {
                // Auto-detect IIIF if URL hints at it, or if content looks like JSON
                var tileSource = SKImagePyramidIiifSource.Parse(content);
                _controller.Load(tileSource, _delayProvider!);
                SyncZoomFromViewport();
                _statusText = $"{tileSource.ImageWidth}×{tileSource.ImageHeight}  ({tileSource.MaxLevel + 1} levels, IIIF)";
            }
            else
            {
                string tilesBase = $"{baseDir}{stem}_files/";
                var tileSource = SKImagePyramidDziSource.Parse(content, tilesBase);
                _controller.Load(tileSource, _delayProvider!);
                SyncZoomFromViewport();
                _statusText = $"{tileSource.ImageWidth}×{tileSource.ImageHeight}  ({tileSource.MaxLevel + 1} levels)";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load: {ex.Message}";
            _statusText = null;
        }
        finally
        {
            _urlLoading = false;
        }

        await InvokeAsync(StateHasChanged);
        await InvokeAsync(() => _canvas?.Invalidate());
    }

    // --- Mouse pan ---
    private void OnMouseDown(MouseEventArgs e)
    {
        _isDragging = true;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging || _controller == null) return;
        var dx = e.ClientX - _lastMouseX;
        var dy = e.ClientY - _lastMouseY;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
        _controller.Pan(dx, dy);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        _isDragging = false;
    }

    // --- Touch pan (mobile) ---
    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _isDragging = true;
            _lastMouseX = e.Touches[0].ClientX;
            _lastMouseY = e.Touches[0].ClientY;
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (!_isDragging || _controller == null || e.Touches.Length == 0) return;
        var dx = e.Touches[0].ClientX - _lastMouseX;
        var dy = e.Touches[0].ClientY - _lastMouseY;
        _lastMouseX = e.Touches[0].ClientX;
        _lastMouseY = e.Touches[0].ClientY;
        _controller.Pan(dx, dy);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnTouchEnd(TouchEventArgs e)
    {
        _isDragging = false;
    }

    private void ToggleInspector()
    {
        _showInspector = !_showInspector;
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void SyncZoomFromViewport()
    {
        _zoom = _controller?.Viewport.Zoom ?? 1.0;
        _sliderValue = ZoomToSlider(Math.Clamp(_zoom, MinZoom, MaxZoom));
    }

    private void OnDebugOptionsChanged()
    {
        if (_debugRenderer == null || _controller == null) return;
        _debugRenderer.ShowTileBorders = _showTileBorders;
        _controller.EnableLodBlending = _enableLodBlending;
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnDebugZoomChanged()
        => InvokeAsync(() => _canvas?.Invalidate());

    private void OnCacheDelayChanged()
    {
        if (_delayProvider == null) return;
        _delayProvider.IsEnabled  = _cacheDelayEnabled;
        _delayProvider.MinDelayMs = _cacheDelayMin;
        _delayProvider.MaxDelayMs = _cacheDelayMax;
        // Do NOT clear the render buffer here: existing lower-level tiles are needed as LOD fallbacks.
        // Use the "Clear Cache" button to reset explicitly.
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnCacheTypeChanged()
    {
        if (_controller == null) return;
        var source = _controller.TileSource;
        RebuildProvider();
        if (source != null)
            _controller.Load(source, _delayProvider!);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnCacheSizeChanged()
    {
        if (_controller == null) return;
        var source = _controller.TileSource;
        RebuildProvider();
        if (source != null)
            _controller.Load(source, _delayProvider!);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnClearCache()
    {
        _controller?.Cache.Clear();
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private ISKImagePyramidTileProvider BuildInnerProvider()
    {
        var http = new SkiaSharp.Extended.SKImagePyramidHttpTileProvider();
        if (_useBrowserCache)
            return new BrowserStorageTileProvider(http, JS);
        return http;
    }

    private DelayTileProvider BuildDelayProvider() => new(BuildInnerProvider())
    {
        IsEnabled  = _cacheDelayEnabled,
        MinDelayMs = _cacheDelayMin,
        MaxDelayMs = _cacheDelayMax,
    };

    private void RebuildProvider()
    {
        if (_controller == null) return;

        var newProvider = BuildDelayProvider();

        // ReplaceProvider disposes the old _delayProvider (which cascades to the inner provider).
        _controller.ReplaceProvider(newProvider);
        _delayProvider = newProvider;

        if (_debugRenderer != null)
            _debugRenderer.ShowTileBorders = _showTileBorders;
    }

    public async ValueTask DisposeAsync()
    {
        _inspectorTimer?.Dispose();
        try { await JS.InvokeVoidAsync("deepZoomUnregisterResize"); } catch { }
        _thisRef?.Dispose();
        if (_controller != null)
        {
            _controller.InvalidateRequired -= OnInvalidateRequired;
            _controller.Dispose(); // also disposes the current _delayProvider chain
        }
        else
        {
            // Defensive: controller never set (OnAfterRenderAsync didn't run) — dispose provider directly.
            _delayProvider?.Dispose();
        }
        _debugRenderer?.Dispose();
    }
}


