@page "/lottie"

<PageTitle>Lottie</PageTitle>

<h1>Lottie Animation</h1>

<p>
    Play Lottie animations using the <code>SKLottieView</code> Blazor component.
    The same <code>SKLottiePlayer</code> logic is shared between this Blazor
    component and the .NET MAUI <code>SKLottieView</code>.
</p>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label">Repeat Mode</label>
        <select class="form-select" @bind="repeatMode">
            <option value="@SKLottieRepeatMode.Restart">Restart</option>
            <option value="@SKLottieRepeatMode.Reverse">Reverse</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">Speed (@(animationSpeed)&#x78;)</label>
        <input type="range" class="form-range speed-slider"
               min="-3" max="3" step="0.25"
               @bind="animationSpeed" />
    </div>
    <div class="col-auto">
        <label class="form-label">Repeat Count</label>
        <select class="form-select" @bind="repeatCount">
            <option value="0">None</option>
            <option value="1">1&#xD7;</option>
            <option value="2">2&#xD7;</option>
            <option value="-1">Infinite</option>
        </select>
    </div>
    <div class="col-auto pt-4">
        <button class="btn btn-outline-secondary" @onclick="() => lottieView?.Restart()">&#x21BA; Restart</button>
    </div>
</div>

<div class="row mb-2">
    <div class="col">
        @if (lottieView?.IsLoading == true)
        {
            <div class="d-flex align-items-center">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                <span>Loading animation…</span>
            </div>
        }
        else if (lottieView?.HasAnimation != true)
        {
            <span class="text-danger">Failed to load animation.</span>
        }
        else
        {
            <span class="text-muted small">
                Duration: @lottieView.Duration.TotalSeconds.ToString("0.00")s &nbsp;|&nbsp;
                Progress: @lottieView.Progress.TotalSeconds.ToString("0.00")s &nbsp;|&nbsp;
                @(lottieView.IsComplete ? "Complete ✓" : "Playing")
            </span>
        }
    </div>
</div>

<div class="row">
    <div class="col-auto">
        <div class="lottie-wrapper">
            <SKLottieView @ref="lottieView"
                          Source="animations/trophy.json"
                          RepeatMode="repeatMode"
                          RepeatCount="repeatCount"
                          AnimationSpeed="animationSpeed"
                          AnimationUpdated="StateHasChanged"
                          style="width: 100%; height: 100%;" />
        </div>
    </div>
</div>

@code {
    private SKLottieView? lottieView;
    private SKLottieRepeatMode repeatMode = SKLottieRepeatMode.Restart;
    private double animationSpeed = 1.0;
    private int repeatCount = -1;
}
