@page "/deepzoom"
@implements IDisposable
@inject HttpClient Http
@using SkiaSharp.Extended.DeepZoom

<PageTitle>Deep Zoom</PageTitle>

<h1>Deep Zoom</h1>

<p>
    A gigapixel-capable image viewer powered by <code>SKDeepZoomController</code>.
    Tiles are loaded on demand at the resolution that best matches the canvas size.
    The image is rendered centered and scaled to fit.
</p>

@if (_statusText != null)
{
    <p class="text-muted"><small>@_statusText</small></p>
}

@if (_errorMessage != null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<SKCanvasView @ref="_canvas"
              OnPaintSurface="OnPaintSurface"
              style="width: 100%; height: 600px; border: 1px solid #ccc;" />

@code {
    private SKCanvasView? _canvas;
    private SKDeepZoomController? _controller;
    private string? _statusText;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _controller = new SKDeepZoomController();
        _controller.InvalidateRequired += OnInvalidateRequired;

        try
        {
            var dziXml = await Http.GetStringAsync("deepzoom/testgrid.dzi");
            var baseUrl = new Uri(Http.BaseAddress!, "deepzoom/testgrid_files/").ToString();
            var tileSource = SKDeepZoomImageSource.Parse(dziXml, baseUrl);

            _controller.Load(tileSource, new SKDeepZoomHttpTileFetcher(new HttpClient()));

            _statusText = $"{tileSource.ImageWidth}×{tileSource.ImageHeight}  ({tileSource.MaxLevel + 1} levels)";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        if (_controller == null) return;

        _controller.SetControlSize(e.Info.Width, e.Info.Height);
        _controller.Update();
        _controller.Render(e.Surface.Canvas);
    }

    private void OnInvalidateRequired(object? sender, EventArgs e)
        => InvokeAsync(() => _canvas?.Invalidate());

    public void Dispose()
    {
        if (_controller != null)
        {
            _controller.InvalidateRequired -= OnInvalidateRequired;
            _controller.Dispose();
        }
    }
}

