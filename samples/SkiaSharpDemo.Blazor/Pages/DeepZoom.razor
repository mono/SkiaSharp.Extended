@page "/deepzoom"
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@using SkiaSharp.Extended.DeepZoom

<PageTitle>Deep Zoom</PageTitle>

<div class="dz-toolbar">
    <label>Zoom: <strong class="dz-zoom-label">@_zoom.ToString("F2")×</strong></label>
    <input type="range" min="0" max="1" step="0.001" value="@_sliderValue"
           @oninput="OnZoomSlider" style="width:200px;vertical-align:middle;" />
    <button @onclick="OnResetView" style="margin-left:8px;">Fit</button>
    <div class="dz-url-row">
        <input type="url" @bind="_urlInput" @bind:event="oninput" placeholder="Enter DZI or DZC URL…"
               @onkeydown="OnUrlKeyDown" class="dz-url-input" />
        <button @onclick="OnLoadUrl" disabled="@_urlLoading">@(_urlLoading ? "Loading…" : "Load")</button>
    </div>
</div>

<div class="dz-layout @(_showInspector ? "dz-with-inspector" : "")">

    <div class="dz-canvas-area"
         @onmousedown="OnMouseDown"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp"
         @ontouchstart="OnTouchStart"
         @ontouchmove="OnTouchMove"
         @ontouchend="OnTouchEnd"
         @ontouchstart:preventDefault
         @ontouchmove:preventDefault>
        @if (_statusText != null)
        {
            <div class="dz-status">@_statusText</div>
        }
        @if (_errorMessage != null)
        {
            <div class="dz-error">@_errorMessage</div>
        }
        <SKGLView @ref="_canvas"
                  OnPaintSurface="OnPaintSurface"
                  class="dz-canvas" />
    </div>

    @if (_showInspector)
    {
        <aside class="dz-inspector">
            <h3>🔍 Inspector</h3>

            @if (_controller?.TileSource is { } src)
            {
                <section>
                    <h4>Image Source</h4>
                    <dl>
                        <dt>Dimensions</dt><dd>@src.ImageWidth × @src.ImageHeight px</dd>
                        <dt>Tile size</dt><dd>@src.TileSize px (+@src.Overlap overlap)</dd>
                        <dt>Format</dt><dd>@src.Format</dd>
                        <dt>Levels</dt><dd>@(src.MaxLevel + 1)  (0–@src.MaxLevel)</dd>
                        <dt>Aspect ratio</dt><dd>@src.AspectRatio.ToString("F4")</dd>
                    </dl>
                </section>
            }
            else
            {
                <p class="dz-muted">No source loaded.</p>
            }

            @if (_controller != null)
            {
                var vp = _controller.Viewport;
                <section>
                    <h4>Viewport</h4>
                    <dl>
                        <dt>Control size</dt><dd>@vp.ControlWidth.ToString("F0") × @vp.ControlHeight.ToString("F0")</dd>
                        <dt>Viewport width</dt><dd>@vp.ViewportWidth.ToString("F6")</dd>
                        <dt>Viewport height</dt><dd>@vp.ViewportHeight.ToString("F6")</dd>
                        <dt>Origin</dt><dd>(@vp.ViewportOriginX.ToString("F6"), @vp.ViewportOriginY.ToString("F6"))</dd>
                        <dt>Scale</dt><dd>@vp.Scale.ToString("F2") px/unit</dd>
                        <dt>Zoom</dt><dd>@vp.Zoom.ToString("F2")×</dd>
                    </dl>
                </section>

                @if (_controller.TileSource is { } lvlSrc)
                {
                    var vp2 = _controller.Viewport;
                    var optLevel = lvlSrc.GetOptimalLevel(vp2.ViewportWidth, vp2.ControlWidth);
                    var levelW = lvlSrc.GetLevelWidth(optLevel);
                    var levelH = lvlSrc.GetLevelHeight(optLevel);
                    // Tile logical width = tileSize / levelWidth; screen pixels = logical * scale
                    double tilePxW = lvlSrc.TileSize * vp2.Scale / levelW;
                    double tilePxH = lvlSrc.TileSize * vp2.Scale / levelH / lvlSrc.AspectRatio;
                    double nativeZoom = (double)lvlSrc.ImageWidth / vp2.ControlWidth;
                    // Show warning only when zoom exceeds native 1:1 — i.e. tiles are being upscaled
                    bool isUpscaling = optLevel >= lvlSrc.MaxLevel && vp2.Zoom > nativeZoom;

                    <section>
                        <h4>Level Selection</h4>
                        <dl>
                            <dt>Current level</dt><dd>@optLevel / @lvlSrc.MaxLevel @(isUpscaling ? "⚠️" : "")</dd>
                            <dt>Level dims</dt><dd>@levelW × @levelH px</dd>
                            <dt>Tile actual size</dt><dd>@lvlSrc.TileSize × @lvlSrc.TileSize px</dd>
                            <dt>Tile on screen</dt><dd>@tilePxW.ToString("F1") × @tilePxH.ToString("F1") px</dd>
                            <dt>Native 1:1 zoom</dt><dd>≈ @nativeZoom.ToString("F2")×</dd>
                        </dl>
                        @if (isUpscaling)
                        {
                            <p class="dz-muted">⚠️ Max detail — level @lvlSrc.MaxLevel (@levelW×@levelH) is native resolution. Zooming further upscales tiles.</p>
                        }
                    </section>
                }

                var cache = _controller.Cache;
                <section>
                    <h4>Tile Cache</h4>
                    <dl>
                        <dt>Cached</dt><dd>@cache.Count / @CacheCapacity</dd>
                        <dt>Pending</dt><dd>@_controller.PendingTileCount</dd>
                        <dt>Status</dt><dd>@(_controller.IsIdle ? "✅ Idle" : "⏳ Loading…")</dd>
                    </dl>
                </section>

                <section>
                    <h4>Visible Tiles</h4>
                    @if (_controller.TileSource != null)
                    {
                        var tiles = _controller.Scheduler.GetVisibleTiles(_controller.TileSource, _controller.Viewport);
                        <p class="dz-muted">@tiles.Count tile(s) at current viewport</p>
                        <table class="dz-tile-table">
                            <thead><tr><th>Lvl</th><th>Col</th><th>Row</th><th>Pri</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var t in tiles.Take(50))
                                {
                                    var cached = cache.Contains(t.TileId);
                                    <tr class="@(cached ? "tile-ok" : "tile-missing")">
                                        <td>@t.TileId.Level</td>
                                        <td>@t.TileId.Col</td>
                                        <td>@t.TileId.Row</td>
                                        <td>@t.Priority.ToString("F2")</td>
                                        <td>@(cached ? "✅" : "⏳")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (tiles.Count > 50)
                        {
                            <p class="dz-muted">… and @(tiles.Count - 50) more</p>
                        }
                    }
                    else
                    {
                        <p class="dz-muted">No source loaded.</p>
                    }
                </section>

                <section>
                    <h4>🔧 Debug</h4>
                    <label class="dz-debug-label">
                        <input type="checkbox" @bind="_showTileBorders" @bind:after="OnDebugOptionsChanged" />
                        Show Tile Borders
                    </label>
                    <label class="dz-debug-label">
                        <input type="checkbox" @bind="_showDebugStats" @bind:after="OnDebugOptionsChanged" />
                        Show Stats Overlay
                    </label>
                </section>

                <section>
                    <h4>🐌 Cache Delay</h4>
                    <label class="dz-debug-label">
                        <input type="checkbox" @bind="_cacheDelayEnabled" @bind:after="OnCacheDelayChanged" />
                        Simulate tile delay
                    </label>
                    <label class="dz-label-row">
                        Min <strong class="dz-zoom-label">@_cacheDelayMin ms</strong>
                        <input type="range" min="0" max="2500" step="10" @bind="_cacheDelayMin" @bind:after="OnCacheDelayChanged" />
                    </label>
                    <label class="dz-label-row">
                        Max <strong class="dz-zoom-label">@_cacheDelayMax ms</strong>
                        <input type="range" min="0" max="2500" step="10" @bind="_cacheDelayMax" @bind:after="OnCacheDelayChanged" />
                    </label>
                </section>
            }
        </aside>
    }
</div>

<button class="dz-toggle-btn" @onclick="ToggleInspector">
    @(_showInspector ? "Hide Inspector" : "Show Inspector")
</button>

<style>
    .dz-toolbar {
        padding: 6px 8px;
        background: #222;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: #ddd;
        cursor: default;
        user-select: none;
    }

    .dz-zoom-label {
        display: inline-block;
        min-width: 7.5ch;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .dz-layout {
        display: flex;
        width: 100%;
        height: calc(100vh - 155px);
        min-height: 300px;
    }

    .dz-canvas-area {
        position: relative;
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-width: 0;
        cursor: grab;
        touch-action: none; /* Prevent browser scroll/zoom on touch */
    }

    .dz-canvas-area.dragging {
        cursor: grabbing;
    }

    .dz-canvas {
        flex: 1 1 auto;
        width: 100%;
        height: 100%;
        display: block;
    }

    .dz-inspector {
        flex: 0 0 320px;
        overflow-y: auto;
        border-left: 1px solid #444;
        padding: 0.75rem;
        font-size: 0.8rem;
        font-family: monospace;
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .dz-inspector h3 { margin: 0 0 0.5rem; font-size: 1rem; }
    .dz-inspector h4 { margin: 0.75rem 0 0.25rem; color: #90caf9; border-bottom: 1px solid #333; padding-bottom: 2px; }
    .dz-inspector dl { display: grid; grid-template-columns: auto 1fr; gap: 2px 8px; margin: 0; }
    .dz-inspector dt { color: #aaa; white-space: nowrap; }
    .dz-inspector dd { margin: 0; word-break: break-all; }
    .dz-inspector section { margin-bottom: 0.5rem; }

    .dz-tile-table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
    .dz-tile-table th, .dz-tile-table td { padding: 1px 4px; text-align: center; }
    .dz-tile-table th { color: #90caf9; }
    .tile-ok td { color: #81c784; }
    .tile-missing td { color: #ffb74d; }

    .dz-status { padding: 4px 8px; background: #222; font-size: 0.8rem; color: #aaa; }
    .dz-error { padding: 4px 8px; background: #5c1010; color: #ff8a80; font-size: 0.8rem; }
    .dz-muted { color: #888; font-size: 0.75rem; margin: 2px 0; }

    .dz-debug-label {
        display: flex;
        align-items: center;
        gap: 6px;
        margin: 4px 0;
        cursor: pointer;
        user-select: none;
    }

    .dz-label-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin: 4px 0;
        font-size: 0.82rem;
        user-select: none;
    }

    .dz-label-row input[type=range] {
        flex: 1 1 auto;
        min-width: 0;
    }

    .dz-toggle-btn {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        z-index: 100;
        padding: 0.4rem 0.8rem;
        background: #1976d2;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.8rem;
    }
    .dz-toggle-btn:hover { background: #1565c0; }

    .dz-url-row {
        display: flex;
        flex: 1 1 auto;
        gap: 4px;
        min-width: 0;
    }

    .dz-url-input {
        flex: 1 1 auto;
        min-width: 0;
        background: #333;
        color: #eee;
        border: 1px solid #555;
        border-radius: 3px;
        padding: 2px 6px;
        font-size: 0.8rem;
    }
</style>

@code {
    private const string DefaultDziUrl =
        "https://raw.githubusercontent.com/mono/SkiaSharp.Extended/refs/heads/main/resources/collections/testgrid/testgrid.dzi";

    private SKGLView? _canvas;
    private SKDeepZoomController? _controller;
    private string? _statusText;
    private string? _errorMessage;
    private bool _showInspector = true;

    // Debug overlay toggles
    private bool _showTileBorders;
    private bool _showDebugStats;
    private bool _cacheDelayEnabled;
    private int  _cacheDelayMin;
    private int  _cacheDelayMax = 500;
    private DelayTileCache? _delayCache;
    private const int CacheCapacity = 1024;

    // URL input
    private string _urlInput = DefaultDziUrl;
    private bool _urlLoading = false;

    // Pan state
    private bool _isDragging;
    private double _lastMouseX;
    private double _lastMouseY;

    // Zoom slider value (1.0 = image fills control width)
    private double _zoom = 1.0;
    // Logarithmic slider position (0-1)
    private double _sliderValue = 0.0;

    // Log zoom range for the slider
    private const double MinZoom = 0.01;
    private const double MaxZoom = 100.0;
    private static double ZoomToSlider(double zoom)
        => (Math.Log(zoom) - Math.Log(MinZoom)) / (Math.Log(MaxZoom) - Math.Log(MinZoom));
    private static double SliderToZoom(double slider)
        => MinZoom * Math.Pow(MaxZoom / MinZoom, slider);

    private System.Threading.Timer? _inspectorTimer;
    private DotNetObjectReference<DeepZoom>? _thisRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Wire up window-resize → canvas invalidate via JS
        _thisRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("deepZoomRegisterResize", _thisRef);

        _delayCache = new DelayTileCache(new SkiaSharp.Extended.DeepZoom.SKDeepZoomTileCache(CacheCapacity));
        _controller = new SKDeepZoomController(_delayCache);
        _controller.InvalidateRequired += OnInvalidateRequired;

        // Refresh inspector every 250ms while loading tiles
        _inspectorTimer = new System.Threading.Timer(_ =>
        {
            // Keep slider in sync with viewport zoom
            if (_controller != null)
                SyncZoomFromViewport();
            InvokeAsync(StateHasChanged);
        }, null, 250, 250);

        await LoadFromUrlAsync(DefaultDziUrl);
    }

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        if (_controller == null) return;
        _controller.SetControlSize(e.BackendRenderTarget.Width, e.BackendRenderTarget.Height);
        _controller.Update();
        _controller.Render(e.Surface.Canvas);
    }

    private void OnInvalidateRequired(object? sender, EventArgs e)
        => InvokeAsync(() => _canvas?.Invalidate());

    [JSInvokable]
    public void OnWindowResize() => InvokeAsync(() => _canvas?.Invalidate());

    // --- Zoom slider ---
    private void OnZoomSlider(ChangeEventArgs e)
    {
        if (_controller == null) return;
        if (!double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var sliderPos)) return;
        _sliderValue = sliderPos;
        _zoom = SliderToZoom(sliderPos);
        _controller.SetZoom(_zoom);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnResetView()
    {
        if (_controller == null) return;
        _controller.ResetView();
        SyncZoomFromViewport();
        InvokeAsync(() => _canvas?.Invalidate());
    }

    // --- URL loading ---
    private async Task OnUrlKeyDown(KeyboardEventArgs e)
    {
        if (_urlLoading) return;
        if (e.Key == "Enter") await OnLoadUrl();
    }

    private async Task OnLoadUrl()
    {
        var url = _urlInput?.Trim();
        if (string.IsNullOrEmpty(url)) return;
        await LoadFromUrlAsync(url);
    }

    /// <summary>
    /// Fetches a DZI or DZC URL, parses it, and loads it into the controller.
    /// Derives the tiles base URL from the manifest URL automatically.
    /// </summary>
    private async Task LoadFromUrlAsync(string url)
    {
        if (_controller == null) return;
        _urlLoading = true;
        _errorMessage = null;
        _statusText = "Loading…";
        StateHasChanged();

        try
        {
            var xml = await Http.GetStringAsync(url);

            // Derive tiles base URL: strip the filename, append _files/ for DZI
            bool isDzc = url.EndsWith(".dzc", StringComparison.OrdinalIgnoreCase);
            string baseDir = url[..url.LastIndexOf('/')] + "/";
            string stem    = System.IO.Path.GetFileNameWithoutExtension(url);

            if (isDzc)
            {
                var coll = SKDeepZoomCollectionSource.Parse(xml);
                coll.TilesBaseUri = baseDir;
                _controller.Load(coll, new SKDeepZoomHttpTileFetcher());
                SyncZoomFromViewport();
                _statusText = $"⚠️ Collection loaded ({coll.ItemCount} images) — DZC collection rendering not yet supported. Use a .dzi URL instead.";
            }
            else
            {
                string tilesBase = $"{baseDir}{stem}_files/";
                var tileSource = SKDeepZoomImageSource.Parse(xml, tilesBase);
                _controller.Load(tileSource, new SKDeepZoomHttpTileFetcher());
                SyncZoomFromViewport();
                _statusText = $"{tileSource.ImageWidth}×{tileSource.ImageHeight}  ({tileSource.MaxLevel + 1} levels)";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load: {ex.Message}";
            _statusText = null;
        }
        finally
        {
            _urlLoading = false;
        }

        await InvokeAsync(StateHasChanged);
        await InvokeAsync(() => _canvas?.Invalidate());
    }

    // --- Mouse pan ---
    private void OnMouseDown(MouseEventArgs e)
    {
        _isDragging = true;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging || _controller == null) return;
        var dx = e.ClientX - _lastMouseX;
        var dy = e.ClientY - _lastMouseY;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
        _controller.Pan(dx, dy);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        _isDragging = false;
    }

    // --- Touch pan (mobile) ---
    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _isDragging = true;
            _lastMouseX = e.Touches[0].ClientX;
            _lastMouseY = e.Touches[0].ClientY;
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (!_isDragging || _controller == null || e.Touches.Length == 0) return;
        var dx = e.Touches[0].ClientX - _lastMouseX;
        var dy = e.Touches[0].ClientY - _lastMouseY;
        _lastMouseX = e.Touches[0].ClientX;
        _lastMouseY = e.Touches[0].ClientY;
        _controller.Pan(dx, dy);
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnTouchEnd(TouchEventArgs e)
    {
        _isDragging = false;
    }

    private void ToggleInspector()
    {
        _showInspector = !_showInspector;
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void SyncZoomFromViewport()
    {
        _zoom = _controller?.Viewport.Zoom ?? 1.0;
        _sliderValue = ZoomToSlider(Math.Clamp(_zoom, MinZoom, MaxZoom));
    }

    private void OnDebugOptionsChanged()
    {
        if (_controller == null) return;
        _controller.ShowTileBorders = _showTileBorders;
        _controller.ShowDebugStats  = _showDebugStats;
        InvokeAsync(() => _canvas?.Invalidate());
    }

    private void OnCacheDelayChanged()
    {
        if (_delayCache == null) return;
        _delayCache.IsEnabled  = _cacheDelayEnabled;
        _delayCache.MinDelayMs = _cacheDelayMin;
        _delayCache.MaxDelayMs = _cacheDelayMax;
        // Clear cache so new tiles load with the updated delay settings
        if (_cacheDelayEnabled)
            _controller?.Cache.Clear();
        InvokeAsync(() => _canvas?.Invalidate());
    }

    public async ValueTask DisposeAsync()
    {
        _inspectorTimer?.Dispose();
        try { await JS.InvokeVoidAsync("deepZoomUnregisterResize"); } catch { }
        _thisRef?.Dispose();
        if (_controller != null)
        {
            _controller.InvalidateRequired -= OnInvalidateRequired;
            _controller.Dispose();
        }
    }
}

