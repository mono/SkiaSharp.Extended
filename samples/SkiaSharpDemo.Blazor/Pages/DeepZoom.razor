@page "/deepzoom"
@implements IDisposable
@inject HttpClient Http
@using SkiaSharp.Extended.DeepZoom

<PageTitle>Deep Zoom</PageTitle>

<h1>Deep Zoom</h1>

<p>
    A gigapixel-capable image viewer powered by <code>SKDeepZoomController</code>.
    Tiles are loaded on demand at the resolution that best matches the canvas size.
    The image is rendered centered and scaled to fit.
</p>

@if (_statusText != null)
{
    <p class="text-muted"><small>@_statusText</small></p>
}

@if (_errorMessage != null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<SKGLView @ref="_canvas"
          OnPaintSurface="OnPaintSurface"
          style="width: 100%; height: 600px; border: 1px solid #ccc;" />

@code {
    // Testgrid DZI served directly from the main branch on GitHub.
    private const string DziUrl =
        "https://raw.githubusercontent.com/mono/SkiaSharp.Extended/refs/heads/main/resources/collections/testgrid/testgrid.dzi";
    private const string TilesBaseUrl =
        "https://raw.githubusercontent.com/mono/SkiaSharp.Extended/refs/heads/main/resources/collections/testgrid/testgrid_files/";

    private SKGLView? _canvas;
    private SKDeepZoomController? _controller;
    private string? _statusText;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _controller = new SKDeepZoomController();
        _controller.InvalidateRequired += OnInvalidateRequired;

        try
        {
            _statusText = "Loading…";
            StateHasChanged();

            var dziXml = await Http.GetStringAsync(DziUrl);
            var tileSource = SKDeepZoomImageSource.Parse(dziXml, TilesBaseUrl);

            _controller.Load(tileSource, new SKDeepZoomHttpTileFetcher(new HttpClient()));

            _statusText = $"{tileSource.ImageWidth}×{tileSource.ImageHeight}  ({tileSource.MaxLevel + 1} levels)";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load: {ex.Message}";
            _statusText = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        if (_controller == null) return;

        _controller.SetControlSize(e.BackendRenderTarget.Width, e.BackendRenderTarget.Height);
        _controller.Update();
        _controller.Render(e.Surface.Canvas);
    }

    private void OnInvalidateRequired(object? sender, EventArgs e)
        => InvokeAsync(() => _canvas?.Invalidate());

    public void Dispose()
    {
        if (_controller != null)
        {
            _controller.InvalidateRequired -= OnInvalidateRequired;
            _controller.Dispose();
        }
    }
}

