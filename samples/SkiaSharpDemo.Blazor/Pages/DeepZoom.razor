@page "/deepzoom"
@implements IDisposable
@inject HttpClient Http
@using SkiaSharp.Extended.DeepZoom
@using SkiaSharpDemo.Blazor.Components

<PageTitle>Deep Zoom</PageTitle>

<h1>Deep Zoom</h1>

<p>
    Pan, zoom, and explore a tiled deep zoom image powered by
    <code>SKDeepZoomController</code> from the shared core library.
    Use mouse wheel to zoom, click and drag to pan, double-click to zoom in/out.
</p>

<div class="row mb-3">
    <div class="col-auto">
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _view?.Reset()">Reset</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _view?.ZoomIn()">Zoom In</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _view?.ZoomOut()">Zoom Out</button>
    </div>
    <div class="col-auto d-flex align-items-center">
        <div class="form-check form-switch me-3">
            <input class="form-check-input" type="checkbox" id="showBorders" @bind="showBorders" />
            <label class="form-check-label" for="showBorders">Tile Borders</label>
        </div>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="showStats" @bind="showStats" />
            <label class="form-check-label" for="showStats">Stats</label>
        </div>
    </div>
    <div class="col-auto d-flex align-items-center">
        <small class="text-muted">@statusText</small>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<SKDeepZoomView @ref="_view"
                TileSource="@_tileSource"
                Fetcher="@_fetcher"
                ShowTileBorders="@showBorders"
                ShowDebugStats="@showStats"
                Style="height: 600px; border: 1px solid #ccc;" />

@code {
    private SKDeepZoomView? _view;
    private ISKDeepZoomTileSource? _tileSource;
    private ISKDeepZoomTileFetcher? _fetcher;

    private bool showBorders;
    private bool showStats;
    private string statusText = "Loading...";
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var dziXml = await Http.GetStringAsync("deepzoom/testgrid.dzi");
            var baseUrl = new Uri(Http.BaseAddress!, "deepzoom/testgrid_files/").ToString();
            _tileSource = SKDeepZoomImageSource.Parse(dziXml, baseUrl);
            _fetcher = new SKDeepZoomHttpTileFetcher(new HttpClient());

            statusText = $"{_tileSource.ImageWidth}×{_tileSource.ImageHeight}, {_tileSource.MaxLevel + 1} levels";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        (_fetcher as IDisposable)?.Dispose();
    }
}

