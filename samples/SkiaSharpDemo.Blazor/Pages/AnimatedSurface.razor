@page "/animatedsurface"

<PageTitle>Animated Surface</PageTitle>

<h1>Animated Surface View</h1>

<p>
    A frame-update loop powered by <code>SKAnimatedSurfaceView</code> from
    <code>SkiaSharp.Extended.UI.Blazor</code>. The component drives a ~60 fps
    <code>PeriodicTimer</code> and calls back each frame for update and paint.
</p>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label">Animation</label>
        <div class="form-check form-switch mt-1">
            <input class="form-check-input" type="checkbox" id="enabledSwitch" @bind="isEnabled" />
            <label class="form-check-label" for="enabledSwitch">
                @(isEnabled ? "Running" : "Paused")
            </label>
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label">Speed (@(speed)&#xD7;)</label>
        <input type="range" class="form-range speed-slider"
               min="0.25" max="4" step="0.25" @bind="speed" />
    </div>
</div>

<div class="canvas-wrapper">
    <SKAnimatedSurfaceView IsAnimationEnabled="isEnabled"
                           OnUpdate="HandleUpdate"
                           OnPaintSurface="HandlePaintSurface"
                           style="width: 100%; height: 100%;" />
</div>

<div class="mt-2 text-muted small">
    <code>angle = @angle.ToString("0.0")°</code>
</div>

@code {
    private bool isEnabled = true;
    private double speed = 1.0;
    private float angle = 0f;

    private void HandleUpdate(TimeSpan delta)
    {
        // Rotate 90° per second, scaled by speed
        angle += (float)(delta.TotalSeconds * 90.0 * speed);
        if (angle >= 360f)
            angle -= 360f;
    }

    private void HandlePaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        var size = new SKSize(e.Info.Width, e.Info.Height);

        canvas.Clear(SKColors.White);

        var cx = size.Width / 2f;
        var cy = size.Height / 2f;
        var side = Math.Min(cx, cy) * 0.6f;

        canvas.Save();
        canvas.Translate(cx, cy);
        canvas.RotateDegrees(angle);

        using var fillPaint = new SKPaint
        {
            IsAntialias = true,
            Color = SKColors.CornflowerBlue
        };
        canvas.DrawRect(-side, -side, side * 2, side * 2, fillPaint);

        using var strokePaint = new SKPaint
        {
            IsAntialias = true,
            Style = SKPaintStyle.Stroke,
            Color = SKColors.DarkBlue,
            StrokeWidth = 4
        };
        canvas.DrawRect(-side, -side, side * 2, side * 2, strokePaint);

        canvas.Restore();
    }
}
