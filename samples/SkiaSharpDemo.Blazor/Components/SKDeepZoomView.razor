@using SkiaSharp.Extended.DeepZoom
@implements IDisposable

<div @onpointerdown="OnPointerDown"
     @onpointermove="OnPointerMove"
     @onpointerup="OnPointerUp"
     @onpointercancel="OnPointerCancel"
     @onwheel="OnWheel"
     @onwheel:preventDefault
     style="touch-action: none; cursor: grab; user-select: none; @AdditionalStyle">
    <SKCanvasView @ref="_canvasView"
                  OnPaintSurface="OnPaintSurface"
                  style="width: 100%; height: 100%;" />
</div>

@code {
    private SKCanvasView? _canvasView;
    private SKDeepZoomController? _controller;
    private bool _suppressTransformSync;
    private float _displayScale = 1f;

    private readonly SKGestureTracker _tracker = new(new SKGestureTrackerOptions
    {
        IsRotateEnabled = false,
        IsDoubleTapZoomEnabled = true,
        IsScrollZoomEnabled = true,
        IsFlingEnabled = true,
        MinScale = 0.001f,  // Zoom-out floor is enforced by viewport MaxViewportWidth via Constrain()
        MaxScale = 32f,
    });

    // ── Parameters ─────────────────────────────────────────────────────────

    /// <summary>Tile source loaded from a .dzi file. Set after calling Load().</summary>
    [Parameter] public SKDeepZoomImageSource? TileSource { get; set; }

    /// <summary>Fetcher used to retrieve tiles. Set together with TileSource.</summary>
    [Parameter] public ISKDeepZoomTileFetcher? Fetcher { get; set; }

    /// <summary>Show tile borders for debugging.</summary>
    [Parameter] public bool ShowTileBorders { get; set; }

    /// <summary>Show a debug statistics overlay.</summary>
    [Parameter] public bool ShowDebugStats { get; set; }

    /// <summary>Additional CSS to apply to the container div (e.g. "height: 600px; border: 1px solid #ccc;").</summary>
    [Parameter] public string? Style { get; set; }

    private string AdditionalStyle => Style ?? "height: 600px;";

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _tracker.TransformChanged += OnTrackerTransformChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (TileSource != null && Fetcher != null && _controller != null)
        {
            _controller.Load(TileSource, Fetcher);
        }
        await base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _controller = new SKDeepZoomController();
        _controller.InvalidateRequired += (_, _) => InvokeAsync(() => _canvasView?.Invalidate());
        // After controller sets fit viewport, sync tracker from it (don't reset tracker to scale=1)
        _controller.ImageOpenSucceeded += (_, _) => SyncTrackerFromViewport();

        if (TileSource != null && Fetcher != null)
            _controller.Load(TileSource, Fetcher);

        await InvokeAsync(StateHasChanged);
    }

    // ── Public API ─────────────────────────────────────────────────────────

    /// <summary>Load a tile source and start rendering.</summary>
    public void Load(SKDeepZoomImageSource tileSource, ISKDeepZoomTileFetcher fetcher)
    {
        _controller?.Load(tileSource, fetcher);
    }

    /// <summary>Reset the viewport to fit the entire image.</summary>
    public void Reset()
    {
        _controller?.ResetView();
        SyncTrackerFromViewport();
    }

    /// <summary>Zoom in by 2× about the center of the view.</summary>
    public void ZoomIn() => ZoomAboutCenter(2f);

    /// <summary>Zoom out by 0.5× about the center of the view.</summary>
    public void ZoomOut() => ZoomAboutCenter(0.5f);

    private void ZoomAboutCenter(float factor)
    {
        if (_controller == null) return;
        var cx = (float)(_controller.Viewport.ControlWidth / 2);
        var cy = (float)(_controller.Viewport.ControlHeight / 2);
        _tracker.ZoomTo(factor, new SKPoint(cx, cy));
    }

    // ── Tracker → Viewport sync ────────────────────────────────────────────

    private void OnTrackerTransformChanged(object? sender, EventArgs e)
    {
        if (_suppressTransformSync || _controller == null) return;

        var controlW = _controller.Viewport.ControlWidth;
        if (controlW <= 0)
        {
            InvokeAsync(() => _canvasView?.Invalidate());
            return;
        }

        double scale = _tracker.Scale;
        _controller.Viewport.ViewportWidth = 1.0 / scale;
        _controller.Viewport.ViewportOriginX = -_tracker.Offset.X / (controlW * scale);
        _controller.Viewport.ViewportOriginY = -_tracker.Offset.Y / (controlW * scale);
        _controller.Viewport.Constrain();

        SyncTrackerFromViewport();

        InvokeAsync(() => _canvasView?.Invalidate());
    }

    private void SyncTrackerFromViewport()
    {
        if (_controller == null) return;
        var vp = _controller.Viewport;
        float newScale = (float)(1.0 / vp.ViewportWidth);
        float offsetX = (float)(-vp.ViewportOriginX * vp.ControlWidth * newScale);
        float offsetY = (float)(-vp.ViewportOriginY * vp.ControlWidth * newScale);

        _suppressTransformSync = true;
        _tracker.SetTransform(newScale, 0f, new SKPoint(offsetX, offsetY));
        _suppressTransformSync = false;
    }

    // ── Rendering ─────────────────────────────────────────────────────────

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        if (_controller == null) return;

        var info = e.Info;
        const float expectedCssHeight = 600f;
        _displayScale = info.Height / expectedCssHeight;

        _controller.ShowTileBorders = ShowTileBorders;
        _controller.ShowDebugStats = ShowDebugStats;
        _controller.SetControlSize(info.Width, info.Height);
        _controller.Update();
        e.Surface.Canvas.Clear(SKColors.White);
        _controller.Render(e.Surface.Canvas);
    }

    // ── Pointer Events ─────────────────────────────────────────────────────

    private void OnPointerDown(PointerEventArgs e)
        => _tracker.ProcessTouchDown(e.PointerId, GetCanvasLocation(e), e.PointerType == "mouse");

    private void OnPointerMove(PointerEventArgs e)
        => _tracker.ProcessTouchMove(e.PointerId, GetCanvasLocation(e), e.Buttons > 0 || e.PointerType != "mouse");

    private void OnPointerUp(PointerEventArgs e)
        => _tracker.ProcessTouchUp(e.PointerId, GetCanvasLocation(e), e.PointerType == "mouse");

    private void OnPointerCancel(PointerEventArgs e)
        => _tracker.ProcessTouchCancel(e.PointerId);

    private void OnWheel(WheelEventArgs e)
    {
        var location = new SKPoint((float)e.OffsetX * _displayScale, (float)e.OffsetY * _displayScale);
        _tracker.ProcessMouseWheel(location, 0, e.DeltaY < 0 ? 1f : -1f);
    }

    private SKPoint GetCanvasLocation(PointerEventArgs e)
        => new SKPoint((float)e.OffsetX * _displayScale, (float)e.OffsetY * _displayScale);

    // ── Disposal ──────────────────────────────────────────────────────────

    public void Dispose()
    {
        _tracker.TransformChanged -= OnTrackerTransformChanged;
        _tracker.Dispose();
        _controller?.Dispose();
    }
}
