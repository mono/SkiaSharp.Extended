@using SkiaSharp.Extended

<aside class="dz-inspector">
    <h3>🔍 Inspector</h3>

    @if (Controller != null)
    {
        <details open>
            <summary>🔧 Debug &amp; Cache</summary>
            <div class="dz-section-body">
                <label class="dz-debug-label">
                    <input type="checkbox" checked="@ShowTileBorders"
                           @onchange="async e => { await ShowTileBordersChanged.InvokeAsync((bool)e.Value!); await OnDebugOptionsChanged.InvokeAsync(); }" />
                    Show Tile Borders
                </label>
                <label class="dz-debug-label">
                    <input type="checkbox" checked="@EnableLodBlending"
                           @onchange="async e => { await EnableLodBlendingChanged.InvokeAsync((bool)e.Value!); await OnDebugOptionsChanged.InvokeAsync(); }" />
                    Enable LOD Blending
                </label>
                <label class="dz-debug-label">
                    <input type="checkbox" checked="@UseBrowserCache"
                           @onchange="async e => { await UseBrowserCacheChanged.InvokeAsync((bool)e.Value!); await OnCacheTypeChanged.InvokeAsync(); }" />
                    Use browser storage cache (L2)
                </label>
                <label class="dz-debug-label">
                    <input type="checkbox" checked="@CacheDelayEnabled"
                           @onchange="async e => { await CacheDelayEnabledChanged.InvokeAsync((bool)e.Value!); await OnCacheDelayChanged.InvokeAsync(); }" />
                    Simulate tile delay (demo)
                </label>
                @if (CacheDelayEnabled)
                {
                    <label class="dz-label-row">
                        Min <strong class="dz-ms-label">@CacheDelayMin ms</strong>
                        <input type="range" min="0" max="2500" step="10" value="@CacheDelayMin"
                               @onchange="async e => { await CacheDelayMinChanged.InvokeAsync(int.Parse(e.Value!.ToString()!)); await OnCacheDelayChanged.InvokeAsync(); }" />
                    </label>
                    <label class="dz-label-row">
                        Max <strong class="dz-ms-label">@CacheDelayMax ms</strong>
                        <input type="range" min="0" max="2500" step="10" value="@CacheDelayMax"
                               @onchange="async e => { await CacheDelayMaxChanged.InvokeAsync(int.Parse(e.Value!.ToString()!)); await OnCacheDelayChanged.InvokeAsync(); }" />
                    </label>
                }
                <label class="dz-label-row">
                    Cache size <strong class="dz-ms-label">@CacheCapacity</strong>
                    <input type="range" min="64" max="4096" step="64" value="@CacheCapacity"
                           @onchange="async e => { await CacheCapacityChanged.InvokeAsync(int.Parse(e.Value!.ToString()!)); await OnCacheSizeChanged.InvokeAsync(); }" />
                </label>
                <button class="dz-small-btn" @onclick="OnClearCache">Clear Cache</button>
            </div>
        </details>

        @if (Controller.TileSource is { } src)
        {
            <details open>
                <summary>🖼 Image Source</summary>
                <div class="dz-section-body">
                    <dl>
                        <dt>Dimensions</dt><dd>@src.ImageWidth × @src.ImageHeight px</dd>
                        @if (src is SKImagePyramidDziSource dzi)
                        {
                            <dt>Tile size</dt><dd>@dzi.TileSize px (+@dzi.Overlap overlap)</dd>
                            <dt>Format</dt><dd>@dzi.Format</dd>
                        }
                        else if (src is SKImagePyramidIiifSource iiif)
                        {
                            <dt>Tile size</dt><dd>@iiif.TileWidth × @iiif.TileHeight px</dd>
                            <dt>Format</dt><dd>@iiif.Format (IIIF)</dd>
                        }
                        <dt>Levels</dt><dd>@(src.MaxLevel + 1)  (0–@src.MaxLevel)</dd>
                        <dt>Aspect ratio</dt><dd>@src.AspectRatio.ToString("F4")</dd>
                    </dl>
                </div>
            </details>
        }
        else
        {
            <p class="dz-muted">No source loaded.</p>
        }

        <details open>
            <summary>📐 Viewport</summary>
            <div class="dz-section-body">
                @{ var vp = Controller.Viewport; }
                <dl>
                    <dt>Control size</dt><dd>@vp.ControlWidth.ToString("F0") × @vp.ControlHeight.ToString("F0")</dd>
                    <dt>Viewport width</dt><dd>@vp.ViewportWidth.ToString("F6")</dd>
                    <dt>Viewport height</dt><dd>@vp.ViewportHeight.ToString("F6")</dd>
                    <dt>Origin</dt><dd>(@vp.ViewportOriginX.ToString("F6"), @vp.ViewportOriginY.ToString("F6"))</dd>
                    <dt>Scale</dt><dd>@vp.Scale.ToString("F2") px/unit</dd>
                    <dt>Zoom</dt><dd>@vp.Zoom.ToString("F2")×</dd>
                </dl>
            </div>
        </details>

        @if (Controller.TileSource is { } lvlSrc)
        {
            var vp2 = Controller.Viewport;
            var optLevel = lvlSrc.GetOptimalLevel(vp2.ViewportWidth, vp2.ControlWidth);
            var levelW = lvlSrc.GetLevelWidth(optLevel);
            var levelH = lvlSrc.GetLevelHeight(optLevel);
            int tileW = lvlSrc is SKImagePyramidDziSource dzi2 ? dzi2.TileSize : (lvlSrc is SKImagePyramidIiifSource iiif2 ? iiif2.TileWidth : 256);
            int tileH = lvlSrc is SKImagePyramidDziSource dzi3 ? dzi3.TileSize : (lvlSrc is SKImagePyramidIiifSource iiif3 ? iiif3.TileHeight : 256);
            double tilePxW = tileW * vp2.Scale / levelW;
            double tilePxH = tileH * vp2.Scale / levelH / lvlSrc.AspectRatio;
            double nativeZoom = (double)lvlSrc.ImageWidth / vp2.ControlWidth;
            bool isUpscaling = optLevel >= lvlSrc.MaxLevel && vp2.Zoom > nativeZoom;

            <details open>
                <summary>🔢 Level Selection</summary>
                <div class="dz-section-body">
                    <dl>
                        <dt>Current level</dt><dd>@optLevel / @lvlSrc.MaxLevel @(isUpscaling ? "⚠️" : "")</dd>
                        <dt>Level dims</dt><dd>@levelW × @levelH px</dd>
                        <dt>Tile actual size</dt><dd>@tileW × @tileH px</dd>
                        <dt>Tile on screen</dt><dd>@tilePxW.ToString("F1") × @tilePxH.ToString("F1") px</dd>
                        <dt>Native 1:1 zoom</dt><dd>≈ @nativeZoom.ToString("F2")×</dd>
                    </dl>
                    @if (isUpscaling)
                    {
                        <p class="dz-muted">⚠️ Max detail — level @lvlSrc.MaxLevel (@levelW×@levelH) is native resolution. Zooming further upscales tiles.</p>
                    }
                </div>
            </details>
        }

        <details open>
            <summary>🗄 Tile Cache</summary>
            <div class="dz-section-body">
                @{ var cache = Controller.Cache; }
                <dl>
                    <dt>Cached</dt><dd>@cache.Count / @CacheCapacity</dd>
                    <dt>Pending</dt><dd>@Controller.PendingTileCount</dd>
                    <dt>Status</dt><dd>@(Controller.IsIdle ? "✅ Idle" : "⏳ Loading…")</dd>
                </dl>
            </div>
        </details>

        <details open>
            <summary>📋 Visible Tiles</summary>
            <div class="dz-section-body">
                @if (Controller.TileSource != null)
                {
                    var tiles = Controller.TileLayout.GetVisibleTiles(Controller.TileSource, Controller.Viewport);
                    <p class="dz-muted">@tiles.Count tile(s) at current viewport</p>
                    <table class="dz-tile-table">
                        <thead><tr><th>Lvl</th><th>Col</th><th>Row</th><th>Pri</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var t in tiles.Take(50))
                            {
                                var cached = Controller.Cache.Contains(t.TileId);
                                <tr class="@(cached ? "tile-ok" : "tile-missing")">
                                    <td>@t.TileId.Level</td>
                                    <td>@t.TileId.Col</td>
                                    <td>@t.TileId.Row</td>
                                    <td>@t.Priority.ToString("F2")</td>
                                    <td>@(cached ? "✅" : "⏳")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (tiles.Count > 50)
                    {
                        <p class="dz-muted">… and @(tiles.Count - 50) more</p>
                    }
                }
                else
                {
                    <p class="dz-muted">No source loaded.</p>
                }
            </div>
        </details>
    }
    else
    {
        <p class="dz-muted">No source loaded.</p>
    }
</aside>

@code {
    [Parameter] public SKImagePyramidController? Controller { get; set; }

    [Parameter] public bool ShowTileBorders { get; set; }
    [Parameter] public EventCallback<bool> ShowTileBordersChanged { get; set; }

    [Parameter] public bool EnableLodBlending { get; set; }
    [Parameter] public EventCallback<bool> EnableLodBlendingChanged { get; set; }

    [Parameter] public bool UseBrowserCache { get; set; }
    [Parameter] public EventCallback<bool> UseBrowserCacheChanged { get; set; }

    [Parameter] public bool CacheDelayEnabled { get; set; }
    [Parameter] public EventCallback<bool> CacheDelayEnabledChanged { get; set; }

    [Parameter] public int CacheDelayMin { get; set; }
    [Parameter] public EventCallback<int> CacheDelayMinChanged { get; set; }

    [Parameter] public int CacheDelayMax { get; set; }
    [Parameter] public EventCallback<int> CacheDelayMaxChanged { get; set; }

    [Parameter] public int CacheCapacity { get; set; }
    [Parameter] public EventCallback<int> CacheCapacityChanged { get; set; }

    [Parameter] public EventCallback OnDebugOptionsChanged { get; set; }
    [Parameter] public EventCallback OnCacheTypeChanged { get; set; }
    [Parameter] public EventCallback OnCacheDelayChanged { get; set; }
    [Parameter] public EventCallback OnCacheSizeChanged { get; set; }
    [Parameter] public EventCallback OnClearCache { get; set; }
}
