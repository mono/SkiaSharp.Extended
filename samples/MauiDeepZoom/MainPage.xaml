<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dz="clr-namespace:SkiaSharp.Extended.UI.Maui.DeepZoom;assembly=SkiaSharp.Extended.UI.Maui.DeepZoom"
             x:Class="MauiDeepZoom.MainPage"
             Title="Deep Zoom Test">

    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Grid.Row="0" Spacing="8" Padding="8" BackgroundColor="#333">
            <Label x:Name="statusLabel" Text="Loading..." TextColor="White" VerticalOptions="Center" />
            <Button Text="Reset" Clicked="OnReset" BackgroundColor="#555" TextColor="White" />
            <Button Text="Zoom In" Clicked="OnZoomIn" BackgroundColor="#555" TextColor="White" />
            <Button Text="Zoom Out" Clicked="OnZoomOut" BackgroundColor="#555" TextColor="White" />
            <Switch x:Name="debugSwitch" IsToggled="True" Toggled="OnDebugToggled" />
            <Label Text="Borders" TextColor="White" VerticalOptions="Center" />
            <Label x:Name="zoomLabel" Text="1.0x" TextColor="Yellow" VerticalOptions="Center" FontAttributes="Bold" />
        </HorizontalStackLayout>

        <dz:SKDeepZoomView x:Name="deepZoomView" Grid.Row="1" />
    </Grid>

</ContentPage>
